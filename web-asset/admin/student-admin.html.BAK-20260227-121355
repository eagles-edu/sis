    function renderOverviewLineChart(levelRows = []) {
      const svg = document.getElementById("overviewLineChart")
      if (!svg) return
      if (!levelRows.length) {
        svg.innerHTML = '<text x="20" y="40" font-size="14" fill="#5f6d87">No assignment completion data yet.</text>'
        return
      }

      const width = 900
      const height = 280
      const padLeft = 48
      const padRight = 20
      const padTop = 20
      const padBottom = 56
      const chartWidth = width - padLeft - padRight
      const chartHeight = height - padTop - padBottom
      const maxValue = Math.max(
        1,
        ...levelRows.map((row) => Math.max(Number(row.totalAssignments || 0), Number(row.completedAssignments || 0)))
      )
      const stepX = levelRows.length > 1 ? chartWidth / (levelRows.length - 1) : 0
      const xAt = (index) => padLeft + stepX * index
      const yAt = (value) => padTop + chartHeight - (Number(value || 0) / maxValue) * chartHeight

      const assignedPoints = levelRows.map((row, index) => `${xAt(index)},${yAt(row.totalAssignments)}`).join(" ")
      const completedPoints = levelRows.map((row, index) => `${xAt(index)},${yAt(row.completedAssignments)}`).join(" ")

      const xLabels = levelRows
        .map((row, index) => `<text x="${xAt(index)}" y="${height - 28}" text-anchor="middle" font-size="10" fill="#65748a">${shortLevelLabel(row.level)}</text>`)
        .join("")

      const yTicks = [0, 0.25, 0.5, 0.75, 1].map((ratio) => {
        const value = Math.round(maxValue * ratio)
        const y = padTop + chartHeight - chartHeight * ratio
        return `<line x1="${padLeft}" y1="${y}" x2="${width - padRight}" y2="${y}" stroke="#e4ebf6" /><text x="${padLeft - 8}" y="${y + 4}" text-anchor="end" font-size="10" fill="#7a879b">${value}</text>`
      }).join("")

      svg.innerHTML = `
        <rect x="${padLeft}" y="${padTop}" width="${chartWidth}" height="${chartHeight}" fill="none" stroke="#dbe5f4"></rect>
        ${yTicks}
        <polyline fill="none" stroke="#5c7fc4" stroke-width="3" points="${assignedPoints}"></polyline>
        <polyline fill="none" stroke="#2a9361" stroke-width="3" points="${completedPoints}"></polyline>
        ${levelRows
          .map((row, index) => `<circle cx="${xAt(index)}" cy="${yAt(row.totalAssignments)}" r="3.5" fill="#5c7fc4"></circle><circle cx="${xAt(index)}" cy="${yAt(row.completedAssignments)}" r="3.5" fill="#2a9361"></circle>`)
          .join("")}
        ${xLabels}
      `
    }

