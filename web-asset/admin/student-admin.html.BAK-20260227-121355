    async function saveAssignmentTemplate() {
      const form = collectAssignmentForm()
      if (!form.assignmentTitle && !form.exerciseTitle) {
        throw new Error("Enter assignment title or exercise title before saving a template.")
      }
      const template = normalizeAssignmentTemplate({
        assignmentTitle: form.assignmentTitle || form.exerciseTitle,
        exerciseTitle: form.exerciseTitle,
        dueAt: form.dueAt,
        level: form.level,
        message: form.message,
      })
      const existingIndex = state.assignmentTemplates.findIndex((entry) => entry.id === template.id)
      const nextTemplates = [...state.assignmentTemplates]
      if (existingIndex >= 0) nextTemplates[existingIndex] = template
      else nextTemplates.unshift(template)
      persistAssignmentTemplates(nextTemplates)
      renderAssignmentTemplates()
      setAssignmentStatus(`Template saved: ${template.assignmentTitle || template.exerciseTitle}`)
    }

    async function deleteAssignmentTemplate(templateId = "") {
      const targetId = normalizeText(templateId)
      if (!targetId) {
        const draft = normalizeAssignmentTemplate(collectAssignmentForm())
