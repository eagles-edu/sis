<!DOCTYPE html>
<html lang="en">
<!-- cspell:ignore KET TAYK eggchic YTD Ytd IELTS ielts healthz blinkmacsystemfont blkquot openxmlformats officedocument spreadsheetml -->
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>The Eagles Club Student Info System </title>
  <link href="favicon.ico" rel="shortcut icon" type="image/vnd.microsoft.icon">

  <style>
    :root {

  --font-base:
    system-ui, -apple-system, blinkmacsystemfont, "Segoe UI Variable", "Segoe UI", roboto, "Noto Sans", ubuntu, cantarell, "Liberation Sans", "DejaVu Sans", "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;

  /* prettier-ignore  */
  --font-header:
    system-ui, -apple-system, blinkmacsystemfont, "Segoe UI Variable", "Segoe UI", roboto, "Noto Sans", ubuntu, cantarell, "Liberation Sans", "DejaVu Sans", "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;

  /* Brand core */
  --primary-color: #B50010; /* locked */
  --secondary-color: #f9faff; /* white */
  --tertiary-color: #002786; /* locked */
  --text-color: #212121; /* locked */
  --text-muted: #414141;
  --icon-color-on-lt: #8a94a8; /* locked */
  --icon-color-on-dk: #f5f8ff; /* locked */

  /* Original Layout surfaces */
  --bg: var(--secondary-color);
  --panel: var(--secondary-color);
  --border:  var(--icon-color-on-lt);
  --ink: var(--text-color);
  --ink-muted: var(--ink-muted);
  --brand:var(--tertiary-color);
  --danger: #B50010;

  /* Layout surfaces */
  --background-color: #798ea4; /* page background behind light content */
  --footer-background: #3e4b5b;
  --blkquot-background: #f0f2f5;
  --body-bgcolor: var(--secondary-color); /* body background */
  --surface-color: #eee; /* menu/content surface */
  --surface-muted: #f0f0ee; /* light alt surface */
  --surface-soft: #fffaf0; /* neutral soft background */
  --surface-warm: #fff; /* hover menu warm neutral alt */
  --surface-1: #fffffa; /* medium light surface */
  --surface-2: #fffaf0; /* very light gray surface */
  --link-aaa: #B50010;

  /* Links */
  --link-color: var(--link-aaa); /* derived from brand blue */
  --link-hover: var(--tertiary-color);
  --link-visited: #630094;
  --link-active: var(--primary-color) /* Semantic states */;
  --pager-text-color: var(--text-color);
  --pager-hover-background: #fff;
  --success-color: #0f6d2a;
  --success-bg: #e6f7ee;
  --success-border: #2f7d51;
  --danger-color: #B50010; /* align with primary */
  --danger-bg: #fce9e9;
  --danger-border: #870200;
  --warning-color: #66008e;
  --warning-bg: #f0f0ee;
  --warning-border: #6330da;
  --info-color: #005e8d;
  --info-bg: #d9edf7;
  --info-border: #3a87ad;
  --menu-bg: #f6f8fc;
  --menu-border: #d7dfec;
  --menu-header-bg: #e8eef8;
  --menu-link-bg: #fcfdff;
  --menu-link-active-bg: #d9e8ff;
  --btn-delete-bg: #fbe9ea;
  --btn-delete-border: #e58a92;
  --btn-delete-text: #9b1520;
  --btn-edit-bg: #e8f1ff;
  --btn-edit-border: #7fa6e2;
  --btn-edit-text: #124685;
  --btn-refresh-bg: #e7f5ec;
  --btn-refresh-border: #6cad85;
  --btn-refresh-text: #1f6b3a;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: var(--font-base);
      background: linear-gradient(45deg, var(--background-color) 0%, #8a94a8 100%);
      color: var(--ink);
    }
    .wrap {
      max-width: 1440px;
      margin: 24px auto;
      padding: 16px;
      display: grid;
      gap: 12px;
    }
    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px;
    }
    #authPanel {
      width: 100%;
      max-width: 550px;
      margin: 0 auto;
    }
    #authPanel .row {
      grid-template-columns: 1fr;
    }
    #authPanel .row > [class^="col-"],
    #authPanel .row > [class*=" col-"] {
      grid-column: span 12;
    }
    h1, h2, h3 {
      margin: 0 0 10px;
      font-weight: 700;
      letter-spacing: 0.2px;
    }
    h1 { font-size: 20px; }
    h2 { font-size: 16px; }
    h3 { font-size: 14px; }
    .muted { color: var(--ink-muted); font-size: 12px; }
    .hidden { display: none !important; }
    .row {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      align-items: end;
    }
    .col-2 { grid-column: span 2; }
    .col-3 { grid-column: span 3; }
    .col-4 { grid-column: span 4; }
    .col-5 { grid-column: span 5; }
    .col-6 { grid-column: span 6; }
    .col-8 { grid-column: span 8; }
    .col-1 { grid-column: span 1; }
    .col-12 { grid-column: span 12; }
    label {
      font-size: 12px;
      color: var(--ink-muted);
      display: block;
      margin-bottom: 4px;
    }
    input, select, textarea, button {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px;
      font-size: 13px;
      background: #fff;
      color: var(--ink);
      inline-size: 100%;
    }
    textarea { min-height: 64px; resize: vertical; }
    button {
      cursor: pointer;
      font-weight: 600;
      background: #f8fbff;
    }
    button.primary {
      background: var(--brand);
      border-color: var(--brand);
      color: #fff;
    }
    button.danger {
      background: var(--btn-delete-bg);
      border-color: var(--btn-delete-border);
      color: var(--btn-delete-text);
    }
    button.btn-delete {
      background: var(--btn-delete-bg);
      border-color: var(--btn-delete-border);
      color: var(--btn-delete-text);
    }
    button.btn-edit {
      background: var(--btn-edit-bg);
      border-color: var(--btn-edit-border);
      color: var(--btn-edit-text);
    }
    button.btn-refresh {
      background: var(--btn-refresh-bg);
      border-color: var(--btn-refresh-border);
      color: var(--btn-refresh-text);
    }
    .grid-main {
      display: grid;
      gap: 12px;
      grid-template-columns: minmax(300px, 420px) minmax(0, 1fr);
    }
    .app-shell {
      display: grid;
      gap: 12px;
      grid-template-columns: 240px minmax(0, 1fr);
      align-items: start;
    }
    .app-sidebar {
      position: sticky;
      top: 12px;
    }
    .menu-groups {
      display: grid;
      gap: 10px;
    }
    .menu-group {
      border: 1px solid var(--menu-border);
      border-radius: 8px;
      overflow: hidden;
      background: var(--menu-bg);
    }
    .menu-group-btn {
      border: 0;
      border-radius: 0;
      padding: 10px 12px;
      text-align: left;
      background: var(--menu-header-bg);
      color: var(--ink);
      font-weight: 700;
    }
    .menu-group-links {
      display: none;
      padding: 8px;
      gap: 6px;
    }
    .menu-group.expanded .menu-group-links {
      display: grid;
    }
    .menu-link {
      border: 1px solid var(--menu-border);
      border-radius: 8px;
      padding: 8px 10px;
      text-decoration: none;
      color: var(--ink);
      font-size: 12px;
      background: var(--menu-link-bg);
    }
    .menu-link.active {
      background: var(--menu-link-active-bg);
      border-color: #8ab0e6;
      color: #0a2f66;
    }
    .page-section {
      display: none;
    }
    .page-section.active {
      display: block;
    }
    .page-note {
      line-height: 1.5;
    }
    .permission-role-card {
      border: 1px solid #d8dee9;
      border-radius: 8px;
      background: #fbfcff;
      padding: 10px;
      margin-bottom: 10px;
    }
    .permission-role-title {
      margin: 0 0 8px;
      font-size: 14px;
      font-weight: 700;
      text-transform: capitalize;
    }
    .permission-page-grid {
      display: grid;
      gap: 6px;
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
    .permission-page-item {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
    }
    .permission-page-item input[type="checkbox"] {
      inline-size: auto;
      margin: 0;
    }
    .list-box {
      max-height: 70vh;
      overflow: auto;
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    th, td {
      padding: 8px;
      border-bottom: 1px solid #e9eef7;
      vertical-align: top;
      text-align: left;
    }
    tr.active { background: #edf4ff; }
    .actions {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 8px;
    }
    .actions-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .section-stack {
      display: grid;
      gap: 12px;
    }
    .overview-layout {
      display: grid;
      gap: 12px;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }
    .overview-group {
      border: 1px solid #dfe6f1;
      border-radius: 10px;
      background: #fcfdff;
      padding: 10px;
      display: grid;
      gap: 8px;
      min-width: 0;
    }
    .overview-group h3 {
      margin-bottom: 2px;
    }
    .overview-group.full {
      grid-column: 1 / -1;
    }
    .stats-grid {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 8px;
    }
    .system-health-grid {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      margin-top: 8px;
    }
    .system-health-item {
      border: 1px solid #dfe6f1;
      border-radius: 8px;
      background: #fbfdff;
      padding: 8px;
      display: grid;
      gap: 4px;
    }
    .system-health-item.ok {
      border-color: #8fd0ac;
      background: #effaf4;
    }
    .system-health-item.warn {
      border-color: #e6cf85;
      background: #fff9eb;
    }
    .system-health-item.error {
      border-color: #eba3ad;
      background: #feeff1;
    }
    .system-health-item.pending {
      border-color: #d8deea;
      background: #f7f9fc;
    }
    .system-health-label {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 11px;
      font-weight: 700;
      color: var(--ink);
      text-transform: uppercase;
      letter-spacing: 0.02em;
    }
    .system-health-detail {
      font-size: 11px;
      color: var(--ink-muted);
      line-height: 1.35;
      overflow-wrap: anywhere;
    }
    .led {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      display: inline-block;
      box-shadow: 0 0 0 2px rgba(255, 255, 255, 0.95), 0 0 0 1px #cad4e3;
      background: #b4bfce;
    }
    .led.ok { background: #2f9a61; }
    .led.warn { background: #d5a91f; }
    .led.error { background: #c73b4a; }
    .led.pending { background: #98a7bb; }
    .system-health-summary {
      margin-top: 6px;
    }
    .stat-card {
      border: 1px solid #dfe6f1;
      border-radius: 8px;
      padding: 8px;
      background: #f8fbff;
    }
    .stat-label {
      font-size: 11px;
      color: var(--ink-muted);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .stat-value {
      margin-top: 2px;
      font-size: 18px;
      font-weight: 700;
      color: var(--ink);
    }
    .mini-list {
      max-height: 180px;
      overflow: auto;
      border: 1px solid #dfe6f1;
      border-radius: 8px;
      background: #fbfdff;
      padding: 8px;
      white-space: pre-wrap;
    }
    .chart-shell {
      border: 1px solid #dfe6f1;
      border-radius: 8px;
      background: #fbfdff;
      padding: 8px;
      margin-top: 8px;
    }
    .chart-svg {
      width: 100%;
      min-height: 260px;
      display: block;
      background: linear-gradient(180deg, #ffffff, #f7fbff);
      border-radius: 6px;
    }
    .chart-legend {
      display: flex;
      gap: 12px;
      font-size: 11px;
      color: var(--ink-muted);
      margin-top: 6px;
    }
    .legend-dot {
      width: 9px;
      height: 9px;
      border-radius: 50%;
      display: inline-block;
      margin-right: 5px;
    }
    .legend-dot.assigned { background: #5c7fc4; }
    .legend-dot.completed { background: #2a9361; }
    .bar-chart-shell .chart-svg {
      min-height: 240px;
    }
    .bar-detail-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 2px;
    }
    .bar-detail-actions button {
      inline-size: auto;
      min-width: 120px;
      padding: 6px 10px;
      font-size: 11px;
    }
    .level-detail-panel {
      margin-top: 10px;
      border: 1px solid #cfdced;
      border-radius: 8px;
      background: #f7fbff;
      padding: 8px;
    }
    #levelDetailRows td {
      font-size: 11px;
    }
    .checkbox-inline {
      inline-size: auto;
      margin: 0;
    }
    .menu-toggle-wrap {
      display: none;
    }
    .menu-toggle-btn {
      background: var(--menu-header-bg);
      border-color: var(--menu-border);
      color: var(--ink);
    }
    .hub-status-wrap {
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 6px;
      align-items: center;
    }
    .hub-pill {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      padding: 5px 10px;
      font-size: 11px;
      font-weight: 700;
      border: 1px solid transparent;
      min-height: 30px;
      text-align: center;
      white-space: nowrap;
    }
    .hub-pill.pending {
      color: #785a12;
      background: #fff7e3;
      border-color: #e2c37a;
    }
    .hub-pill.connected {
      color: #155f3f;
      background: #e8f8ee;
      border-color: #78bd95;
    }
    .hub-pill.disconnected {
      color: #84222b;
      background: #fdeced;
      border-color: #e38f98;
    }
    #hubStatusMeta {
      margin-top: 4px;
      font-family: ui-monospace, "SF Mono", menlo, consolas, monospace;
    }
    .small {
      font-size: 11px;
      color: var(--ink-muted);
    }
    #status {
      min-height: 28px;
      white-space: pre-wrap;
      font-size: 12px;
      color: var(--ink-muted);
    }
    @media (max-width: 1100px) {
      .app-shell {
        grid-template-columns: 1fr;
      }
      .app-sidebar {
        position: static;
        display: none;
      }
      body.menu-open .app-sidebar {
        display: block;
      }
      .menu-toggle-wrap {
        display: block;
      }
      .permission-page-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .stats-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .system-health-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
      .overview-layout {
        grid-template-columns: 1fr;
      }
      .overview-group.full {
        grid-column: auto;
      }
      .chart-svg {
        min-height: 220px;
      }
      .grid-main { grid-template-columns: 1fr; }
      .col-2, .col-3, .col-4, .col-6, .col-8 { grid-column: span 12; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel" id="authPanel">
      <h1>Student Admin Login</h1>
      <form id="loginForm">
        <div class="row">
          <div class="col-4">
            <label for="loginUser">Username</label>
            <input id="loginUser" type="text" autocomplete="username" value="admin">
          </div>
          <div class="col-4">
            <label for="loginPass">Password</label>
            <input id="loginPass" type="password" autocomplete="current-password">
          </div>
          <div class="col-2">
            <button id="loginBtn" type="submit" class="primary">Login</button>
          </div>
        </div>
      </form>
      <p class="muted">Session-based secure login is required for all admin API operations.</p>
      <p class="small" id="authStatus" aria-live="polite"></p>
    </div>

    <div id="app" class="hidden">
      <div class="app-shell">
        <aside class="panel app-sidebar">
          <h2>Navigation</h2>
          <p class="small">Expandable section menus keep related tools grouped on separate pages.</p>
          <nav class="menu-groups" id="navMenu">
            <div class="menu-group" data-menu-group="students">
              <button type="button" class="menu-group-btn" data-menu-toggle="students">Students</button>
              <div class="menu-group-links">
                <a href="#" class="menu-link" data-page-link="overview">Overview</a>
                <a href="#" class="menu-link" data-page-link="profile">Profile</a>
              </div>
            </div>
            <div class="menu-group" data-menu-group="tracking">
              <button type="button" class="menu-group-btn" data-menu-toggle="tracking">Tracking</button>
              <div class="menu-group-links">
                <a href="#" class="menu-link" data-page-link="attendance">Attendance</a>
                <a href="#" class="menu-link" data-page-link="assignments">Assignments</a>
                <a href="#" class="menu-link" data-page-link="grades">Grades</a>
                <a href="#" class="menu-link" data-page-link="reports">Reports</a>
              </div>
            </div>
            <div class="menu-group" data-menu-group="support">
              <button type="button" class="menu-group-btn" data-menu-toggle="support">Support</button>
              <div class="menu-group-links">
                <a href="#" class="menu-link" data-page-link="family">Family Lookup</a>
              </div>
            </div>
            <div class="menu-group" data-menu-group="admin">
              <button type="button" class="menu-group-btn" data-menu-toggle="admin">Administration</button>
              <div class="menu-group-links">
                <a href="#" class="menu-link" data-page-link="users">Users</a>
                <a href="#" class="menu-link" data-page-link="permissions">Permissions</a>
                <a href="#" class="menu-link" data-page-link="settings">Settings</a>
              </div>
            </div>
          </nav>
        </aside>

        <div class="section-stack">
          <div class="panel" id="topControlsPanel">
            <div class="row">
              <div class="col-2 menu-toggle-wrap">
                <button id="menuToggleBtn" type="button" class="menu-toggle-btn">Menu</button>
              </div>
              <div class="col-3">
                <label for="searchQ">Search student</label>
                <input id="searchQ" type="search" placeholder="name, student id, parent name">
              </div>
              <div class="col-2">
                <label for="filterLevel">Level</label>
                <select id="filterLevel"><option value="">All levels</option></select>
              </div>
              <div class="col-2" id="schoolFilterCol">
                <label for="filterSchool">School</label>
                <select id="filterSchool"><option value="">All schools</option></select>
              </div>
              <div class="col-3">
                <label for="familyPhone">Family phone lookup</label>
                <input id="familyPhone" type="tel" placeholder="parent emergency phone">
              </div>
              <div class="col-2">
                <button id="searchBtn" type="button">Search</button>
              </div>
              <div class="col-2">
                <button id="familyBtn" type="button">Find Family</button>
              </div>
              <div class="col-2">
                <button id="refreshBtn" type="button" class="btn-refresh">Refresh</button>
              </div>
              <div class="col-2">
                <button id="logoutBtn" type="button" class="danger">Logout</button>
              </div>
              <div class="col-4">
                <label>SIS Hub Connection</label>
                <div class="hub-status-wrap">
                  <span id="hubStatusBadge" class="hub-pill pending">Checking...</span>
                  <button id="hubPingBtn" type="button" class="btn-refresh">Ping Hub</button>
                </div>
                <p class="small" id="hubStatusMeta">waiting for first probe...</p>
              </div>
            </div>
          </div>

          <div class="grid-main">
            <div class="panel" id="studentListPanel">
              <h2>Students</h2>
              <div class="list-box">
                <table>
                  <thead>
                    <tr>
                      <th>Student ID</th>
                      <th>Name</th>
                      <th>Level</th>
                      <th class="school-col">School</th>
                    </tr>
                  </thead>
                  <tbody id="studentRows"></tbody>
                </table>
              </div>
              <p class="small" id="studentCount">0 students</p>

              <hr>
              <h3>Import Spreadsheet (CSV/TSV/XLSX)</h3>
              <div class="row">
                <div class="col-6">
                  <input id="importFile" type="file" accept=".csv,.tsv,.xlsx,.xls,text/csv,text/tab-separated-values,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel">
                </div>
                <div class="col-3">
                  <button id="importTemplateBtn" type="button">Download Template</button>
                </div>
                <div class="col-3">
                  <button id="importBtn" type="button">Import File</button>
                </div>
              </div>
              <p class="small">`studentId` column is required and must be unique.</p>
            </div>

            <div class="section-stack">
              <div class="panel page-section" data-page="overview">
                <h2>Overview</h2>
                <p class="page-note">Dashboard sections are stacked for quick scanning. Use detail buttons by level to send reminders to uncompleted students.</p>
                <p class="small" id="overviewStudent">No student selected.</p>
                <div class="overview-layout">
                  <section class="overview-group">
                    <h3>Systems Health</h3>
                    <div id="systemHealthRows" class="system-health-grid" aria-live="polite"></div>
                    <p class="small system-health-summary" id="systemHealthSummary">Checking systems...</p>
                  </section>
                  <section class="overview-group">
                    <h3>Today Snapshot</h3>
                    <div class="stats-grid" id="overviewStatsGrid">
