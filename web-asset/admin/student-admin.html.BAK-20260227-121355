    function buildFallbackDashboardSummary() {
      const levelMap = new Map()
      const students = assignmentStudentSource()
      students.forEach((student) => {
        const level = normalizeLevelName(student?.profile?.currentGrade || "") || "Unassigned"
        const row = levelMap.get(level) || {
          level,
          enrolledStudents: 0,
          totalAssignments: 0,
          completedAssignments: 0,
          outstandingAssignments: 0,
          completedStudents: 0,
          uncompletedStudents: [],
        }
        row.enrolledStudents += 1
        levelMap.set(level, row)
      })
      const levels = Array.from(levelMap.values()).sort((left, right) =>
        normalizeText(left.level).localeCompare(normalizeText(right.level))
