    document.getElementById("reportGenerateBtn").addEventListener("click", () => generateReport().catch(handleError))
    document.getElementById("reportCardBtn").addEventListener("click", () => downloadReportCard().catch(handleError))
    document.getElementById("reportClearBtn").addEventListener("click", () => {
      document.getElementById("r_id").value = ""
      document.getElementById("r_className").value = ""
      document.getElementById("r_schoolYear").value = ""
      document.getElementById("r_quarter").value = "q1"
      document.getElementById("r_homeworkCompletionRate").value = ""
      document.getElementById("r_homeworkOnTimeRate").value = ""
      document.getElementById("r_behaviorScore").value = ""
      document.getElementById("r_participationScore").value = ""
      document.getElementById("r_inClassScore").value = ""
      document.getElementById("r_comments").value = ""
      setStatus("Report form cleared.")
    })

    state.rolePermissions = normalizeRolePermissionsMap(defaultRolePermissionsConfig())
    state.authRolePolicy = getCurrentRolePolicy()
    renderPermissionsEditor()
    updateNavigationAccess()
    applyUiSettings()
    renderAssignmentTemplates()
    populateProfileLevelOptions()
    populateAssignmentLevelOptions()
    refreshAssignmentStudentOptions()
    renderHubConnectionStatus()
    probeHubConnection({ notify: false }).catch(() => {})

    ;(async () => {
      if (isStaticAdminPreviewMode() && !ADMIN_API_ORIGIN && requiresApiOriginForStaticPreview()) {
        showLogin()
        setStatus(staticPreviewHelpMessage(), true)
        return
      }

      let me = null
      try {
        me = await api("/api/admin/auth/me")
      } catch (error) {
        showLogin()
        if (error && error.status && error.status !== 401) {
          setStatus(error.message || "Unable to restore session.", true)
        }
        return
      }

      state.authUser = me.user || null
      state.authRolePolicy = normalizeRolePolicy(currentRoleName(), me?.rolePolicy, getCurrentRolePolicy())
      showApp()
      setStatus(`Authenticated as ${state.authUser?.username || "admin"}.`)

      try {
        await bootAfterLogin()
      } catch (error) {
        handleError(error)
      }
    })()
  </script>
</body>
</html>
