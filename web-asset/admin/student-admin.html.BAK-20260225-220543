<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>The Eagles Club Student Info System </title>
  <style>
    :root {

  --font-base:
    system-ui, -apple-system, blinkmacsystemfont, "Segoe UI Variable", "Segoe UI", roboto, "Noto Sans", ubuntu, cantarell, "Liberation Sans", "DejaVu Sans", "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;

  /* prettier-ignore  */
  --font-header:
    system-ui, -apple-system, blinkmacsystemfont, "Segoe UI Variable", "Segoe UI", roboto, "Noto Sans", ubuntu, cantarell, "Liberation Sans", "DejaVu Sans", "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;

  /* Brand core */
  --primary-color: #B50010; /* locked */
  --secondary-color: #f9faff; /* white */
  --tertiary-color: #002786; /* locked */
  --text-color: #212121; /* locked */
  --text-muted: #414141;
  --icon-color-on-lt: #8a94a8; /* locked */
  --icon-color-on-dk: #f5f8ff; /* locked */

  /* Original Layout surfaces */
  --bg: var(--secondary-color);
  --panel: var(--secondary-color);
  --border:  var(--icon-color-on-lt);
  --ink: var(--text-color);
  --ink-muted: var(--ink-muted);
  --brand:var(--tertiary-color);
  --danger: #B50010;

  /* Layout surfaces */
  --background-color: #798ea4; /* page background behind light content */
  --footer-background: #3e4b5b;
  --blkquot-background: #f0f2f5;
  --body-bgcolor: var(--secondary-color); /* body background */
  --surface-color: #eee; /* menu/content surface */
  --surface-muted: #f0f0ee; /* light alt surface */
  --surface-soft: #fffaf0; /* neutral soft background */
  --surface-warm: #fff; /* hover menu warm neutral alt */
  --surface-1: #fffffa; /* medium light surface */
  --surface-2: #fffaf0; /* very light gray surface */
  --link-aaa: #B50010;

  /* Links */
  --link-color: var(--link-aaa); /* derived from brand blue */
  --link-hover: var(--tertiary-color);
  --link-visited: #630094;
  --link-active: var(--primary-color) /* Semantic states */;
  --pager-text-color: var(--text-color);
  --pager-hover-background: #fff;
  --success-color: #0f6d2a;
  --success-bg: #e6f7ee;
  --success-border: #2f7d51;
  --danger-color: #B50010; /* align with primary */
  --danger-bg: #fce9e9;
  --danger-border: #870200;
  --warning-color: #66008e;
  --warning-bg: #f0f0ee;
  --warning-border: #6330da;
  --info-color: #005e8d;
  --info-bg: #d9edf7;
  --info-border: #3a87ad;
    }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: "Segoe UI", Tahoma, sans-serif;
      background: linear-gradient(45deg, var(--background-color) 0%, #8a94a8 100%);
      color: var(--ink);
    }
    .wrap {
      max-width: 500px;
      margin: 10% auto;
      padding: 16px;
      display: grid;
      gap: 12px;
    }
    .panel {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 12px;
    }
    h1, h2, h3 {
      margin: 0 0 10px;
      font-weight: 700;
      letter-spacing: 0.2px;
    }
    h1 { font-size: 20px; }
    h2 { font-size: 16px; }
    h3 { font-size: 14px; }
    .muted { color: var(--ink-muted); font-size: 12px; }
    .hidden { display: none !important; }
    .row {
      display: grid;
      gap: 8px;
      grid-template-columns: repeat(12, minmax(0, 1fr));
      align-items: end;
    }
    .col-2 { grid-column: span 2; }
    .col-3 { grid-column: span 3; }
    .col-4 { grid-column: span 4; }
    .col-5 { grid-column: span 5; }
    .col-6 { grid-column: span 6; }
    .col-8 { grid-column: span 8; }
    .col-1 { grid-column: span 1; }
    .col-12 { grid-column: span 12; }
    label {
      font-size: 12px;
      color: var(--ink-muted);
      display: block;
      margin-bottom: 4px;
    }
    input, select, textarea, button {
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 8px;
      font-size: 13px;
      background: #fff;
      color: var(--ink);
      inline-size: 100%;
    }
    textarea { min-height: 64px; resize: vertical; }
    button {
      cursor: pointer;
      font-weight: 600;
      background: #f8fbff;
    }
    button.primary {
      background: var(--brand);
      border-color: var(--brand);
      color: #fff;
    }
    button.danger {
      background: #fff2f2;
      border-color: #efc4c4;
      color: var(--danger);
    }
    .grid-main {
      display: grid;
      gap: 12px;
      grid-template-columns: 360px 1fr;
    }
    .list-box {
      max-height: 70vh;
      overflow: auto;
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
    }
    th, td {
      padding: 8px;
      border-bottom: 1px solid #e9eef7;
      vertical-align: top;
      text-align: left;
    }
    tr.active { background: #edf4ff; }
    .actions {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 8px;
      margin-top: 8px;
    }
    .actions-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .section-stack {
      display: grid;
      gap: 12px;
    }
    .small {
      font-size: 11px;
      color: var(--ink-muted);
    }
    #status {
      min-height: 28px;
      white-space: pre-wrap;
      font-size: 12px;
      color: var(--ink-muted);
    }
    @media (max-width: 1100px) {
      .grid-main { grid-template-columns: 1fr; }
      .col-2, .col-3, .col-4, .col-6, .col-8 { grid-column: span 12; }
    }
  </style>
</head>
<body>
  <div class="wrap">
    <div class="panel" id="authPanel">
      <h1>Student Admin Login</h1>
      <form id="loginForm">
        <div class="row">
          <div class="col-4">
            <label for="loginUser">Username</label>
            <input id="loginUser" type="text" autocomplete="username" value="admin">
          </div>
          <div class="col-4">
            <label for="loginPass">Password</label>
            <input id="loginPass" type="password" autocomplete="current-password">
          </div>
          <div class="col-2">
            <button id="loginBtn" type="submit" class="primary">Login</button>
          </div>
        </div>
      </form>
      <p class="muted">Session-based secure login is required for all admin API operations.</p>
    </div>

    <div id="app" class="hidden section-stack">
      <div class="panel">
        <div class="row">
          <div class="col-3">
            <label for="searchQ">Search student</label>
            <input id="searchQ" type="search" placeholder="name, student id, parent name">
          </div>
          <div class="col-2">
            <label for="filterLevel">Level</label>
            <select id="filterLevel"><option value="">All levels</option></select>
          </div>
          <div class="col-2">
            <label for="filterSchool">School</label>
            <select id="filterSchool"><option value="">All schools</option></select>
          </div>
          <div class="col-3">
            <label for="familyPhone">Family phone lookup</label>
            <input id="familyPhone" type="tel" placeholder="parent emergency phone">
          </div>
          <div class="col-2">
            <button id="searchBtn" type="button">Search</button>
          </div>
          <div class="col-2">
            <button id="familyBtn" type="button">Find Family</button>
          </div>
          <div class="col-2">
            <button id="refreshBtn" type="button">Refresh</button>
          </div>
          <div class="col-2">
            <button id="logoutBtn" type="button" class="danger">Logout</button>
          </div>
        </div>
      </div>

      <div class="panel hidden" id="userAdminPanel">
        <h2>Admin User Management</h2>
        <div class="row">
          <input id="u_id" type="hidden">
          <div class="col-3">
            <label for="u_username">Username *</label>
            <input id="u_username" type="text" autocomplete="username">
          </div>
          <div class="col-2">
            <label for="u_role">Role *</label>
            <select id="u_role">
              <option value="teacher">teacher</option>
              <option value="admin">admin</option>
            </select>
          </div>
          <div class="col-3">
            <label for="u_password">Password</label>
            <input id="u_password" type="password" autocomplete="new-password" placeholder="required for new user">
          </div>
          <div class="col-2">
            <button id="userSaveBtn" type="button" class="primary">Save User</button>
          </div>
          <div class="col-2">
            <button id="userNewBtn" type="button">New User</button>
          </div>
          <div class="col-2">
            <button id="userRefreshBtn" type="button">Refresh Users</button>
          </div>
          <div class="col-2">
            <button id="userDeleteBtn" type="button" class="danger">Delete User</button>
          </div>
        </div>
        <table>
          <thead><tr><th>Username</th><th>Role</th><th>Updated</th><th>Action</th></tr></thead>
          <tbody id="userRows"></tbody>
        </table>
        <p class="small" id="userCount">0 users</p>
      </div>

      <div class="grid-main">
        <div class="panel">
          <h2>Students</h2>
          <div class="list-box">
            <table>
              <thead>
                <tr>
                  <th>Student ID</th>
                  <th>Name</th>
                  <th>Level</th>
                  <th>School</th>
                </tr>
              </thead>
              <tbody id="studentRows"></tbody>
            </table>
          </div>
          <p class="small" id="studentCount">0 students</p>

          <hr>
          <h3>Import Spreadsheet (CSV/TSV/XLSX)</h3>
          <div class="row">
            <div class="col-6">
              <input id="importFile" type="file" accept=".csv,.tsv,.xlsx,.xls,text/csv,text/tab-separated-values,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-excel">
            </div>
            <div class="col-3">
              <button id="importTemplateBtn" type="button">Download Template</button>
            </div>
            <div class="col-3">
              <button id="importBtn" type="button">Import File</button>
            </div>
          </div>
          <p class="small">`studentId` column is required and must be unique.</p>
        </div>

        <div class="section-stack">
          <div class="panel">
            <h2>Student Profile (linked to individual)</h2>
            <div class="row">
              <div class="col-3"><label>Student ID *</label><input id="f_studentId" type="text"></div>
              <div class="col-4"><label>Full Name</label><input id="f_fullName" type="text"></div>
              <div class="col-3"><label>English Name</label><input id="f_englishName" type="text"></div>
              <div class="col-2"><label>Date of Birth</label><input id="f_dobText" type="text"></div>
              <div class="col-12"><label>Photo URL (for PDF report card image)</label><input id="f_photoUrl" type="url" placeholder="https://... or data:image/..."></div>

              <div class="col-3"><label>Student Email</label><input id="f_studentEmail" type="email"></div>
              <div class="col-3"><label>Student Phone (Child)</label><input id="f_studentPhone" type="tel"></div>
              <div class="col-2"><label>Level / Grade</label><input id="f_currentGrade" type="text"></div>
              <div class="col-4"><label>School Name</label><input id="f_schoolName" type="text"></div>

              <div class="col-8"><label>Address</label><input id="f_streetAddress" type="text"></div>
              <div class="col-2"><label>Ward/District</label><input id="f_wardDistrict" type="text"></div>
              <div class="col-2"><label>City</label><input id="f_city" type="text"></div>

              <div class="col-4"><label>Mother Name</label><input id="f_motherName" type="text"></div>
              <div class="col-3"><label>Mother Phone</label><input id="f_motherPhone" type="tel"></div>
              <div class="col-3"><label>Mother Emergency Phone</label><input id="f_motherEmergencyContact" type="tel"></div>
              <div class="col-2"><label>Mother Email</label><input id="f_motherEmail" type="email"></div>

              <div class="col-4"><label>Father Name</label><input id="f_fatherName" type="text"></div>
              <div class="col-3"><label>Father Phone</label><input id="f_fatherPhone" type="tel"></div>
              <div class="col-3"><label>Father Emergency Phone</label><input id="f_fatherEmergencyContact" type="tel"></div>
              <div class="col-2"><label>Father Email</label><input id="f_fatherEmail" type="email"></div>

              <div class="col-12"><label>Comments</label><textarea id="f_extraComments"></textarea></div>
            </div>
            <div class="actions">
              <button id="newBtn" type="button">Create New</button>
              <button id="saveBtn" type="button" class="primary">Save / Update</button>
              <button id="deleteBtn" type="button" class="danger">Delete Student</button>
            </div>
          </div>

          <div class="panel">
            <h2>Attendance by Quarter</h2>
            <div class="row">
              <input id="a_id" type="hidden">
              <div class="col-3"><label>Class</label><input id="a_className" type="text"></div>
              <div class="col-2"><label>School Year</label><input id="a_schoolYear" type="text" placeholder="2026-2027"></div>
              <div class="col-2"><label>Quarter</label><select id="a_quarter"><option>q1</option><option>q2</option><option>q3</option><option>q4</option></select></div>
              <div class="col-2"><label>Date</label><input id="a_date" type="date"></div>
              <div class="col-2"><label>Status</label><select id="a_status"><option>present</option><option>absent</option><option>late</option><option>excused</option></select></div>
              <div class="col-1"><label>&nbsp;</label><button id="attendanceSaveBtn" type="button">Save</button></div>
              <div class="col-12"><label>Comments</label><input id="a_comments" type="text"></div>
            </div>
            <table>
              <thead><tr><th>Date</th><th>Class</th><th>Quarter</th><th>Status</th><th>Comments</th><th>Action</th></tr></thead>
              <tbody id="attendanceRows"></tbody>
            </table>
          </div>

          <div class="panel">
            <h2>Grades / Homework / Behavior / Participation</h2>
            <div class="row">
              <input id="g_id" type="hidden">
              <div class="col-3"><label>Class</label><input id="g_className" type="text"></div>
              <div class="col-2"><label>School Year</label><input id="g_schoolYear" type="text"></div>
              <div class="col-2"><label>Quarter</label><select id="g_quarter"><option>q1</option><option>q2</option><option>q3</option><option>q4</option></select></div>
              <div class="col-5"><label>Assignment</label><input id="g_assignmentName" type="text"></div>

              <div class="col-2"><label>Due Date</label><input id="g_dueAt" type="date"></div>
              <div class="col-2"><label>Submitted Date</label><input id="g_submittedAt" type="date"></div>
              <div class="col-1"><label>Score</label><input id="g_score" type="number" step="0.01"></div>
              <div class="col-1"><label>Max</label><input id="g_maxScore" type="number" step="0.01"></div>
              <div class="col-2"><label>HW Done</label><select id="g_homeworkCompleted"><option value="">-</option><option value="true">Yes</option><option value="false">No</option></select></div>
              <div class="col-2"><label>On Time</label><select id="g_homeworkOnTime"><option value="">-</option><option value="true">Yes</option><option value="false">No</option></select></div>
              <div class="col-2"><label>Behavior</label><input id="g_behaviorScore" type="number"></div>

              <div class="col-2"><label>Participation</label><input id="g_participationScore" type="number"></div>
              <div class="col-2"><label>In Class</label><input id="g_inClassScore" type="number"></div>
              <div class="col-6"><label>Comments</label><input id="g_comments" type="text"></div>
              <div class="col-2"><label>&nbsp;</label><button id="gradeSaveBtn" type="button">Save</button></div>
            </div>
            <table>
              <thead><tr><th>Due</th><th>Class</th><th>Assignment</th><th>Score</th><th>HW</th><th>Behavior</th><th>Participation</th><th>In Class</th><th>Action</th></tr></thead>
              <tbody id="gradeRows"></tbody>
            </table>
          </div>

          <div class="panel">
            <h2>Parent Reports Per Class</h2>
            <div class="row">
              <input id="r_id" type="hidden">
              <div class="col-3"><label>Class</label><input id="r_className" type="text"></div>
              <div class="col-2"><label>School Year</label><input id="r_schoolYear" type="text"></div>
              <div class="col-2"><label>Quarter</label><select id="r_quarter"><option>q1</option><option>q2</option><option>q3</option><option>q4</option></select></div>
              <div class="col-2"><label>HW %</label><input id="r_homeworkCompletionRate" type="number" step="0.01"></div>
              <div class="col-2"><label>On-Time %</label><input id="r_homeworkOnTimeRate" type="number" step="0.01"></div>
              <div class="col-1"><label>&nbsp;</label><button id="reportSaveBtn" type="button">Save</button></div>

              <div class="col-2"><label>Behavior</label><input id="r_behaviorScore" type="number" step="0.01"></div>
              <div class="col-2"><label>Participation</label><input id="r_participationScore" type="number" step="0.01"></div>
              <div class="col-2"><label>In Class</label><input id="r_inClassScore" type="number" step="0.01"></div>
              <div class="col-6"><label>Comments</label><input id="r_comments" type="text"></div>
            </div>
            <div class="actions actions-3">
              <button id="reportGenerateBtn" type="button">Generate from Grade Records</button>
              <button id="reportCardBtn" type="button">Download PDF Report Card</button>
              <button id="reportClearBtn" type="button">Clear Report Form</button>
            </div>
            <table>
              <thead><tr><th>Generated</th><th>Class</th><th>Quarter</th><th>HW %</th><th>On-Time %</th><th>Behavior</th><th>Participation</th><th>In Class</th><th>Action</th></tr></thead>
              <tbody id="reportRows"></tbody>
            </table>
          </div>
        </div>
      </div>

      <div class="panel" id="status"></div>
    </div>
  </div>

  <script>
    const state = {
      authUser: null,
      adminUsers: [],
      currentAdminUser: null,
      students: [],
      currentStudent: null,
    }

    const statusEl = document.getElementById("status")

    const profileFields = [
      "studentId", "fullName", "englishName", "dobText", "photoUrl", "studentEmail", "studentPhone", "currentGrade", "schoolName",
      "streetAddress", "wardDistrict", "city", "motherName", "motherPhone", "motherEmergencyContact", "motherEmail",
      "fatherName", "fatherPhone", "fatherEmergencyContact", "fatherEmail", "extraComments"
    ]

    function setStatus(message, isError = false) {
      statusEl.style.color = isError ? "#bd2f2f" : "#5f6d87"
      statusEl.textContent = message
    }

    function normalizeText(value) {
      if (value === undefined || value === null) return ""
      return String(value).trim()
    }

    const DEFAULT_ADMIN_API_PREFIX = "/api/admin"
    const DEFAULT_ADMIN_PAGE_PATH = "/admin/students"

    function normalizePathPrefix(value, fallback = DEFAULT_ADMIN_API_PREFIX) {
      let normalized = normalizeText(value || fallback)
      if (!normalized) normalized = fallback
      if (!normalized.startsWith("/")) normalized = `/${normalized}`
      if (normalized.length > 1) normalized = normalized.replace(/\/+$/, "")
      return normalized
    }

    function resolveApiPrefix() {
      const params = new URLSearchParams(window.location.search || "")
      const queryPrefix = normalizeText(params.get("apiPrefix"))
      const injectedPrefix = normalizeText(window.__SIS_ADMIN_API_PREFIX)
      let storedPrefix = ""
      try {
        storedPrefix = normalizeText(window.localStorage.getItem("sis.admin.apiPrefix"))
      } catch (error) {
        void error
      }
      const resolvedPrefix = normalizePathPrefix(
        queryPrefix || injectedPrefix || storedPrefix,
        DEFAULT_ADMIN_API_PREFIX
      )

      if (queryPrefix) {
        try {
          window.localStorage.setItem("sis.admin.apiPrefix", resolvedPrefix)
        } catch (error) {
          void error
        }
      }

      return resolvedPrefix
    }

    function resolveAdminPagePath() {
      const injectedPath = normalizeText(window.__SIS_ADMIN_PAGE_PATH)
      return normalizePathPrefix(injectedPath || DEFAULT_ADMIN_PAGE_PATH, DEFAULT_ADMIN_PAGE_PATH)
    }

    function resolveApiOrigin() {
      const params = new URLSearchParams(window.location.search || "")
      const queryOrigin = normalizeText(params.get("apiOrigin"))
      const injectedOrigin = normalizeText(window.__SIS_ADMIN_API_ORIGIN)
      let storedOrigin = ""
      try {
        storedOrigin = normalizeText(window.localStorage.getItem("sis.admin.apiOrigin"))
      } catch (error) {
        void error
      }

      const selectedOrigin = queryOrigin || injectedOrigin || storedOrigin
      if (!selectedOrigin) return ""
      try {
        const resolved = new URL(selectedOrigin, window.location.origin).origin
        if (queryOrigin) {
          try {
            window.localStorage.setItem("sis.admin.apiOrigin", resolved)
          } catch (error) {
            void error
          }
        }
        return resolved
      } catch (error) {
        void error
        return ""
      }
    }

    const ADMIN_API_PREFIX = resolveApiPrefix()
    const ADMIN_PAGE_PATH = resolveAdminPagePath()
    const ADMIN_API_ORIGIN = resolveApiOrigin()

    function resolveApiUrl(path) {
      const rawPath = normalizeText(path)
      if (!rawPath) return rawPath
      if (/^https?:\/\//i.test(rawPath)) return rawPath

      let resolvedPath = rawPath
      if (resolvedPath.startsWith(DEFAULT_ADMIN_API_PREFIX)) {
        resolvedPath = `${ADMIN_API_PREFIX}${resolvedPath.slice(DEFAULT_ADMIN_API_PREFIX.length)}`
      }
      if (!resolvedPath.startsWith("/")) {
        resolvedPath = `/${resolvedPath}`
      }

      if (ADMIN_API_ORIGIN) {
        return new URL(resolvedPath, ADMIN_API_ORIGIN).toString()
      }
      return resolvedPath
    }

    function isStaticAdminPreviewMode() {
      return normalizeText(window.location.pathname).endsWith("/web-asset/admin/student-admin.html")
    }

    function staticPreviewHelpMessage() {
      return `Static preview mode requires ?apiOrigin=http://127.0.0.1:<mailer-port> or opening ${ADMIN_PAGE_PATH}.`
    }

    function assertApiOriginConfiguredForStaticPreview() {
      if (!isStaticAdminPreviewMode() || ADMIN_API_ORIGIN) return
      const error = new Error(staticPreviewHelpMessage())
      error.status = 400
      throw error
    }

    function canManageUsers() {
      return normalizeText(state.authUser?.role).toLowerCase() === "admin"
    }

    function showUserPanel() {
      const panel = document.getElementById("userAdminPanel")
      if (canManageUsers()) panel.classList.remove("hidden")
      else panel.classList.add("hidden")
    }

    function clearUserForm() {
      state.currentAdminUser = null
      document.getElementById("u_id").value = ""
      document.getElementById("u_username").value = ""
      document.getElementById("u_role").value = "teacher"
      document.getElementById("u_password").value = ""
    }

    function fillUserForm(user) {
      state.currentAdminUser = user || null
      document.getElementById("u_id").value = user?.id || ""
      document.getElementById("u_username").value = user?.username || ""
      document.getElementById("u_role").value = user?.role || "teacher"
      document.getElementById("u_password").value = ""
    }

    function formatDateTime(value) {
      const text = normalizeText(value)
      if (!text) return ""
      const parsed = new Date(text)
      if (Number.isNaN(parsed.valueOf())) return text
      return parsed.toLocaleString()
    }

    function selectedStudentId() {
      return state.currentStudent && state.currentStudent.id ? state.currentStudent.id : ""
