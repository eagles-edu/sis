{
  "name": "sis",
  "version": "0.1.0",
  "description": "SIS backend service workspace",
  "private": true,
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "engines": {
    "node": "20.19.4"
  },
  "scripts": {
    "start": "node server/exercise-mailer.mjs",
    "dev": "NODE_ENV=development SIS_ENV_FILE=.env.dev EXERCISE_MAILER_PORT=${EXERCISE_MAILER_PORT:-8788} node server/exercise-mailer.mjs",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:backup": "node tools/db-backup-failsafe.mjs",
    "db:backup:dry": "node tools/db-backup-failsafe.mjs --dry-run",
    "db:backup:no-prune": "node tools/db-backup-failsafe.mjs --no-prune",
    "db:restore": "node tools/db-restore-failsafe.mjs",
    "db:restore:verify": "node tools/db-restore-failsafe.mjs --verify-only",
    "ffs-sis-public-root": "ffs-sis-public-root --batch",
    "ffs-sis-root": "ffs-sis-root --batch",
    "sync:full:sis-public-root": "ffs-sis-public-root --batch",
    "sync:full:sis-root": "ffs-sis-root --batch",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "lint": "npm run lint:html && npm run lint:js && npm run lint:css",
    "lint:html": "html-validate web-asset/admin/student-admin.html",
    "lint:js": "eslint --config eslint.config.mjs server test tools --max-warnings=0",
    "lint:css": "stylelint --config stylelint.config.mjs web-asset/admin/student-admin.html",
    "test": "node --test test/*.spec.mjs",
    "test:redis": "timeout 120s env STUDENT_ADMIN_SESSION_DRIVER=redis STUDENT_ADMIN_SESSION_REDIS_CONNECT_TIMEOUT_MS=1200 REDIS_SESSION_URL=${REDIS_SESSION_URL:-redis://127.0.0.1:6379/0} node --test test/*.spec.mjs",
    "test:session-store": "node --test test/student-admin-session-store.spec.mjs",
    "test:watch": "node --test --watch test/*.spec.mjs",
    "map:deps": "node tools/build-mapping-stack.mjs --deps-only",
    "map:openapi:lint": "redocly lint --config redocly.yaml docs/mapping/openapi/sis-admin.openapi.yaml",
    "map:openapi:build": "redocly build-docs --config redocly.yaml docs/mapping/openapi/sis-admin.openapi.yaml --output docs/mapping/out/sis-admin.openapi.html",
    "map:all": "node tools/build-mapping-stack.mjs"
  },
  "keywords": [
    "sis",
    "student",
    "admin",
    "education"
  ],
  "author": "Eagles Education",
  "license": "ISC",
  "bugs": {},
  "homepage": "",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "@redocly/cli": "^2.20.4",
    "@types/node": "^20.19.35",
    "dependency-cruiser": "^17.3.8",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^16.4.0",
    "html-validate": "^10.0.0",
    "html-validate-markdown": "^5.1.0",
    "html-validate-vue": "^7.3.0",
    "jsdom": "^24.1.0",
    "playwright": "^1.58.2",
    "postcss-html": "^1.8.0",
    "prettier": "^3.7.4",
    "prisma": "^7.4.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^36.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "archiver": "^7.0.1",
    "argparse": "^2.0.1",
    "cheerio": "^1.2.0",
    "css-declaration-sorter": "^7.3.1",
    "cssnano": "^7.1.3",
    "dom-serializer": "^2.0.0",
    "dotenv": "^17.3.1",
    "glob": ">=11.1.0",
    "js-yaml": "^4.1.1",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "redis": "^5.11.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "hono": "4.12.5",
    "lodash": "4.17.23"
  }
}
