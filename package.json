{
  "name": "sis",
  "version": "0.1.0",
  "description": "SIS backend service workspace",
  "private": true,
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "engines": {
    "node": "20.19.4"
  },
  "scripts": {
    "start": "node server/exercise-mailer.mjs",
    "dev": "NODE_ENV=development node server/exercise-mailer.mjs",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:backup": "node tools/db-backup-failsafe.mjs",
    "db:backup:dry": "node tools/db-backup-failsafe.mjs --dry-run",
    "db:backup:no-prune": "node tools/db-backup-failsafe.mjs --no-prune",
    "db:restore": "node tools/db-restore-failsafe.mjs",
    "db:restore:verify": "node tools/db-restore-failsafe.mjs --verify-only",
    "test": "node --test test/*.spec.mjs",
    "test:redis": "timeout 120s env STUDENT_ADMIN_SESSION_DRIVER=redis STUDENT_ADMIN_SESSION_REDIS_CONNECT_TIMEOUT_MS=1200 REDIS_SESSION_URL=${REDIS_SESSION_URL:-redis://127.0.0.1:6379/0} node --test test/*.spec.mjs",
    "test:session-store": "node --test test/student-admin-session-store.spec.mjs",
    "test:watch": "node --test --watch test/*.spec.mjs"
  },
  "keywords": [
    "sis",
    "student",
    "admin",
    "education"
  ],
  "author": "Eagles Education",
  "license": "ISC",
  "bugs": {},
  "homepage": "",
  "devDependencies": {
    "@eslint/js": "^9.36.0",
    "@microsoft/eslint-formatter-sarif": "^3.1.0",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^16.4.0",
    "html-validate": "^10.0.0",
    "html-validate-markdown": "^5.1.0",
    "html-validate-vue": "^7.3.0",
    "jsdom": "^24.1.0",
    "postcss-html": "^1.8.0",
    "prettier": "^3.7.4",
    "prisma": "^7.4.2",
    "stylelint": "^16.24.0",
    "stylelint-config-standard": "^36.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "archiver": "^7.0.1",
    "argparse": "^2.0.1",
    "cheerio": "^1.2.0",
    "css-declaration-sorter": "^7.3.1",
    "cssnano": "^7.1.3",
    "dom-serializer": "^2.0.0",
    "dotenv": "^17.3.1",
    "glob": ">=13.0.6",
    "js-yaml": "^4.1.1",
    "nodemailer": "^7.0.13",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "redis": "^5.11.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "hono": "4.12.5",
    "lodash": "4.17.23"
  }
}
