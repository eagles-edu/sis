{
  "name": "sis",
  "version": "0.1.0",
  "description": "SIS backend service workspace",
  "private": true,
  "type": "module",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "engines": {
    "node": "20.19.4"
  },
  "scripts": {
    "start": "NODE_ENV=production SIS_ENV_FILE=.env node server/exercise-mailer.mjs",
    "dev": "NODE_ENV=development SIS_ENV_FILE=.env.dev node server/exercise-mailer.mjs",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:backup": "node tools/db-backup-failsafe.mjs",
    "db:backup:dry": "node tools/db-backup-failsafe.mjs --dry-run",
    "db:backup:no-prune": "node tools/db-backup-failsafe.mjs --no-prune",
    "db:restore": "node tools/db-restore-failsafe.mjs",
    "db:restore:verify": "node tools/db-restore-failsafe.mjs --verify-only",
    "db:rollover": "node tools/school-year-rollover.mjs archive",
    "db:rollover:inspect": "node tools/school-year-rollover.mjs inspect",
    "db:rollover:help": "node tools/school-year-rollover.mjs --help",
    "db:school-year:migrate-label": "node tools/migrate-school-year-label.mjs",
    "db:auto-import:cleanup-titles": "node tools/cleanup-auto-import-exercise-titles.mjs",
    "db:incoming:vacuum": "node tools/vacuum-incoming-exercise-results.mjs",
    "news:validation:audit": "node tools/news-validation-audit.mjs",
    "db:health:check": "node tools/db-health-check.mjs",
    "ops:incoming:vacuum:cron:check": "tools/install-incoming-vacuum-cron.sh --check-only",
    "ops:maintenance:systemd:check": "tools/install-maintenance-systemd.sh --check-only",
    "ffs-sis-public-root": "ffs-sis-public-root --batch",
    "ffs-sis-root": "ffs-sis-root --batch",
    "sync:full:sis-public-root": "ffs-sis-public-root --batch",
    "sync:full:sis-root": "ffs-sis-root --batch",
    "sync:portal:check": "tools/sync-portal-bidirectional.sh --check-only",
    "sync:portal:dev-to-live": "tools/sync-portal-bidirectional.sh --apply --dev-to-live",
    "sync:portal:live-to-dev": "tools/sync-portal-bidirectional.sh --apply --live-to-dev",
    "sync:proof:portal": "tools/verify-portal-sync-proof.sh",
    "sync:full:sis-root:restart-runtimes": "tools/sync-and-restart-runtimes.sh full",
    "sync:full:sis-public-root:restart-runtimes": "tools/sync-and-restart-runtimes.sh public",
    "runtimes:restart": "tools/sync-and-restart-runtimes.sh restart-only",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "lint": "npm run lint:html && npm run lint:js && npm run lint:css",
    "lint:html": "html-validate web-asset/admin/student-admin.html",
    "lint:js": "eslint --config eslint.config.mjs server test tools --max-warnings=0",
    "lint:css": "stylelint --config stylelint.config.mjs web-asset/admin/student-admin.html",
    "test": "node --test test/*.spec.mjs",
    "test:portal-chip-contract": "node --test test/portal-chip-contract.spec.mjs",
    "test:redis": "timeout 120s env STUDENT_ADMIN_SESSION_DRIVER=redis STUDENT_ADMIN_SESSION_REDIS_CONNECT_TIMEOUT_MS=1200 REDIS_SESSION_URL=${REDIS_SESSION_URL:-redis://127.0.0.1:6379/0} node --test test/*.spec.mjs",
    "test:session-store": "node --test test/student-admin-session-store.spec.mjs",
    "test:watch": "node --test --watch test/*.spec.mjs",
    "map:deps": "node tools/build-mapping-stack.mjs --deps-only",
    "map:openapi:lint": "redocly lint --config redocly.yaml docs/mapping/openapi/sis-admin.openapi.yaml",
    "map:openapi:build": "redocly build-docs --config redocly.yaml docs/mapping/openapi/sis-admin.openapi.yaml --output docs/mapping/out/sis-admin.openapi.html",
    "map:all": "node tools/build-mapping-stack.mjs"
  },
  "keywords": [
    "sis",
    "student",
    "admin",
    "english language education",
    "school",
    "student information system"
  ],
  "author": "The Eagles American English Club, Ltd.",
  "license": "Copyright © 2026 | The Eagles American English Club, Ltd. | All rights reserved",
  "bugs": {},
  "homepage": "",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@redocly/cli": "^2.25.2",
    "@types/node": "^20.19.35",
    "dependency-cruiser": "^17.3.10",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "html-validate": "^10.11.2",
    "html-validate-markdown": "^5.1.0",
    "html-validate-vue": "^8.1.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.58.2",
    "postcss-html": "^1.8.1",
    "prettier": "^3.8.1",
    "prisma": "^7.6.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "archiver": "^7.0.1",
    "argparse": "^2.0.1",
    "cheerio": "^1.2.0",
    "css-declaration-sorter": "^7.3.1",
    "cssnano": "^7.1.3",
    "dom-serializer": "^2.0.0",
    "dotenv": "^17.3.1",
    "glob": ">=11.1.0",
    "js-yaml": "^4.1.1",
    "nodemailer": "^8.0.4",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "redis": "^5.11.0",
    "xlsx": "^0.18.5"
  },
  "overrides": {
    "hono": "4.12.5",
    "lodash": "4.17.23"
  }
}
