{
	"inputs": [
		{
			"id": "browser_url",
			"type": "promptString",
			"description": "Optional: connect to an already-running Chrome (remote debugging / port-forward). Example: http://127.0.0.1:9222",
			"password": false,
			"default": "http://127.0.0.1:5500"
		},
		{
			"id": "headless",
			"type": "promptString",
			"description": "Run Chrome headless (true/false). Default: false",
			"password": false,
			"default": "false"
		},
		{
			"id": "isolated",
			"type": "promptString",
			"description": "Use a temporary user-data-dir (true/false). Default: false",
			"password": false,
			"default": "false"
		},
		{
			"id": "chrome_channel",
			"type": "promptString",
			"description": "Chrome channel: stable | canary | beta | dev (default: stable).",
			"password": false,
			"default": "stable"
		},
		{
			"id": "context7_api_key",
			"type": "promptString",
			"description": "Context7 API key (optional; increases rate limits). Get one at https://context7.com/dashboard",
			"password": true
		},
		{
			"id": "codacy_account_token",
			"type": "promptString",
			"description": "Your Codacy Account API token (from app.codacy.com → Account). Required.",
			"password": true
		},
		{
			"id": "codacy_cli_version",
			"type": "promptString",
			"description": "Optional: pin Codacy CLI version used by local analysis (e.g., 2.3.1).",
			"password": false
		},
		{
			"id": "Authorization",
			"type": "promptString",
			"description": "Authentication token (PAT or App token)",
			"password": true
		},
		{
			"id": "CONTEXT7_API_KEY",
			"type": "promptString",
			"description": "API key for authentication",
			"password": true
		}
	],
	"mcpServers": {
		"github": {
			"url": "https://api.githubcopilot.com/mcp/",
			"type": "http"
		},
		"sequentialthinking": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-sequential-thinking"
			],
			"type": "stdio"
		},
		"github-remote": {
			"url": "https://api.githubcopilot.com/mcp/",
			"id": "github-copilot",
			"type": "http"
		},
		"context7": {
			"command": "npx",
			"args": [
				"--no-update-notifier",
				"-y",
				"@upstash/context7-mcp"
			],
			"type": "stdio"
		},
		"docker": {
			"command": "npx",
			"args": [
				"mcp-server-docker"
			],
			"type": "stdio"
		},
		"everything": {
			"command": "npx",
			"args": [
				"@modelcontextprotocol/server-everything"
			],
			"type": "stdio"
		},
		"git": {
			"command": "uvx",
			"args": [
				"mcp-server-git",
				"--repository",
				"/home/eagles/dockerz/sis"
			],
			"type": "stdio"
		},
		"filesystem": {
			"command": "npx",
			"args": [
				"@modelcontextprotocol/server-filesystem"
			],
			"type": "stdio"
		},
		"memory": {
			"command": "npx",
			"args": [
				"@modelcontextprotocol/server-memory"
			],
			"type": "stdio"
		},
		"chromedevtools/chrome-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"chrome-devtools-mcp@latest",
				"--browserUrl",
				"${input:browser_url}",
				"--headless",
				"${input:headless}",
				"--isolated",
				"${input:isolated}",
				"--channel",
				"${input:chrome_channel}"
			],
			"gallery": "https://api.mcp.github.com/2025-09-15/v0/servers/13749964-2447-4c31-bcab-32731cced504",
			"version": "0.0.1-seed"
		},
		"github/github-mcp-server": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"gallery": "https://api.mcp.github.com/2025-09-15/v0/servers/ab12cd34-5678-90ef-1234-567890abcdef",
			"version": "0.13.0"
		},
		"microsoft/playwright-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"@playwright/mcp@latest"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.0.1-seed"
		},
		"upstash/context7": {
			"type": "http",
			"url": "https://mcp.context7.com/mcp",
			"headers": {
				"CONTEXT7_API_KEY": "${input:context7_api_key}"
			},
			"gallery": "https://api.mcp.github.com/2025-09-15/v0/servers/dcec7705-b81b-4e0f-8615-8032604be7ad",
			"version": "1.0.0"
		},
		"antfu/nuxt-mcp": {
			"type": "http",
			"url": "https://mcp.nuxt.com/sse",
			"gallery": "https://api.mcp.github.com/2025-09-15/v0/servers/7d2aa3fa-ab7a-4609-b27c-7b24037bf6ce",
			"version": "1.0.0"
		},
		"codacy/codacy-mcp-server": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@codacy/codacy-mcp@latest"
			],
			"env": {
				"CODACY_ACCOUNT_TOKEN": "${input:codacy_account_token}",
				"CODACY_CLI_VERSION": "${input:codacy_cli_version}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "1.0.0"
		},
		"io.github.github/github-mcp-server": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"Authorization": "${input:Authorization}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.24.1"
		},
        "colab": {
            "command": "uvx",
            "args": [
                "colab-mcp"
            ],
            "type": "stdio"
        }
	}
}